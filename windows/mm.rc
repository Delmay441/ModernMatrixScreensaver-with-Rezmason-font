// mm.rc — config dialog, screensaver name, and version info.
// ASCII only (rc.exe compiles with the system codepage; non-ASCII here turns into mojibake).
#include <windows.h>
#include <commctrl.h>
#include "resource.h"

// Font Embedding
IDR_MATRIX_FONT RCDATA "Matrix-Code.ttf"

// The classic screensaver-name convention: string id 1 is shown by the Windows
// "Screen Saver Settings" control panel.
STRINGTABLE
BEGIN
    1   "Modern Matrix"
END

// Page 1 of the config dialog's tab control: every slider in the app, grouped
// together and positioned directly under the live preview by the host dialog
// (see PositionPages() in config.cpp).
// This is a child-dialog "page" template, not shown standalone -- IDD_CONFIG 
// creates it into the IDC_TAB display area.
IDD_PAGE_SLIDERS DIALOGEX 0, 0, 272, 220
STYLE DS_SETFONT | DS_CONTROL | WS_CHILD
FONT 9, "Segoe UI", 400, 0, 1
BEGIN
    LTEXT           "Glyph speed", IDC_STATIC, 4, 4, 120, 9
    LTEXT           "Slow", IDC_STATIC, 4, 17, 26, 9
    CONTROL         "", IDC_SPEED, "msctls_trackbar32", TBS_HORZ | WS_TABSTOP, 32, 14, 208, 18
    RTEXT           "Fast", IDC_STATIC, 244, 17, 24, 9

    LTEXT           "Density:", IDC_STATIC, 4, 34, 38, 8
    CONTROL         "", IDC_DENSITY, "msctls_trackbar32", TBS_BOTH | TBS_NOTICKS | WS_TABSTOP, 44, 32, 95, 15
    
    LTEXT           "Glyph Size:", IDC_STATIC, 149, 34, 42, 8
    CONTROL         "", IDC_GLYPH_SCALE, "msctls_trackbar32", TBS_BOTH | TBS_NOTICKS | WS_TABSTOP, 193, 32, 75, 15
    LTEXT           "Small sizes impact CPU!", IDC_WARNING_GLYPH, 149, 49, 119, 8, NOT WS_VISIBLE

    LTEXT           "Column Length", IDC_STATIC, 4, 60, 120, 9
    CONTROL         "", IDC_LENGTH_BIAS, "msctls_trackbar32", TBS_HORZ | WS_TABSTOP, 32, 70, 208, 18

    LTEXT           "Screen curvature", IDC_STATIC, 4, 88, 120, 9
    LTEXT           "Flat", IDC_STATIC, 4, 101, 26, 9
    CONTROL         "", IDC_DISTORTION, "msctls_trackbar32", TBS_HORZ | WS_TABSTOP, 32, 98, 208, 18
    RTEXT           "Curved", IDC_STATIC, 244, 101, 28, 9

    LTEXT           "Scene depth", IDC_STATIC, 4, 116, 120, 9
    LTEXT           "Flat", IDC_STATIC, 4, 129, 26, 9
    CONTROL         "", IDC_DEPTH, "msctls_trackbar32", TBS_HORZ | WS_TABSTOP, 32, 126, 208, 18
    RTEXT           "Deep", IDC_STATIC, 244, 129, 28, 9

    LTEXT           "Glow intensity", IDC_STATIC, 4, 144, 120, 9
    LTEXT           "Subtle", IDC_STATIC, 4, 157, 26, 9
    CONTROL         "", IDC_GLOW, "msctls_trackbar32", TBS_HORZ | WS_TABSTOP, 32, 154, 208, 18
    RTEXT           "Intense", IDC_STATIC, 244, 157, 28, 9

    LTEXT           "Camera speed", IDC_STATIC, 4, 172, 120, 9
    LTEXT           "Still", IDC_STATIC, 4, 185, 26, 9
    CONTROL         "", IDC_CAMSPEED, "msctls_trackbar32", TBS_HORZ | WS_TABSTOP, 32, 182, 208, 18
    RTEXT           "Fast", IDC_STATIC, 244, 185, 24, 9

    LTEXT           "Glyph mutation", IDC_STATIC, 4, 200, 120, 9
    LTEXT           "Stable", IDC_STATIC, 4, 213, 26, 9
    CONTROL         "", IDC_MUTATION, "msctls_trackbar32", TBS_HORZ | WS_TABSTOP, 32, 210, 208, 18
    RTEXT           "Chaotic", IDC_STATIC, 244, 213, 30, 9
END

// Page 2 of the config dialog's tab control: on/off toggles, the easter-egg
// (glitch) switch, and the project link.
IDD_PAGE_OPTIONS DIALOGEX 0, 0, 272, 100
STYLE DS_SETFONT | DS_CONTROL | WS_CHILD
FONT 9, "Segoe UI", 400, 0, 1
BEGIN
    AUTOCHECKBOX    "Textured",        IDC_TEXTURED, 4, 8, 130, 10
    AUTOCHECKBOX    "Wireframe",       IDC_WIREFRAME, 149, 8, 130, 10
    AUTOCHECKBOX    "Show frame rate", IDC_SHOWFPS,  4, 24, 130, 10
    AUTOCHECKBOX    "Bloom glow",      IDC_BLOOM,    149, 24, 130, 10
    AUTOCHECKBOX    "HDR highlights",  IDC_HDR,      4, 40, 130, 10
    AUTOCHECKBOX    "Easter eggs (glitches)", IDC_EASTEREGGS, 149, 40, 140, 10

    CONTROL         "<a href=""https://github.com/Pottypotsworth/ModernMatrixScreensaver"">Project on GitHub</a>",
                    IDC_LINK, "SysLink", WS_TABSTOP, 4, 68, 200, 10
END

IDD_CONFIG DIALOGEX 0, 0, 300, 412
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Modern Matrix - Settings"
FONT 9, "Segoe UI", 400, 0, 1
BEGIN
    // Live preview surface (a child render window is created over this placeholder).
    CONTROL         "", IDC_PREVIEW, "Static", SS_BLACKRECT | WS_VISIBLE, 10, 7, 280, 118

    // Tab control directly below the preview; its two pages (IDD_PAGE_SLIDERS /
    // IDD_PAGE_OPTIONS) are created and positioned into its display area at
    // runtime by config.cpp -- see PositionPages()/ShowPage().
    CONTROL         "", IDC_TAB, "SysTabControl32", WS_TABSTOP, 10, 130, 280, 250

    PUSHBUTTON      "Reset to Defaults", IDC_RESET, 10, 390, 90, 14
    PUSHBUTTON      "Cancel", IDCANCEL, 196, 390, 44, 14
    DEFPUSHBUTTON   "Save", IDOK, 246, 390, 44, 14
END

VS_VERSION_INFO VERSIONINFO
 FILEVERSION 1,0,0,0
 PRODUCTVERSION 1,0,0,0
 FILEOS VOS_NT_WINDOWS32
 FILETYPE VFT_APP
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      "Chewie"
            VALUE "FileDescription",  "Modern Matrix"
            VALUE "FileVersion",      "1.0.0.0"
            VALUE "InternalName",     "ModernMatrix"
            VALUE "OriginalFilename", "ModernMatrix.scr"
            VALUE "ProductName",      "Modern Matrix"
            VALUE "ProductVersion",   "1.0.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 0x04B0
    END
END